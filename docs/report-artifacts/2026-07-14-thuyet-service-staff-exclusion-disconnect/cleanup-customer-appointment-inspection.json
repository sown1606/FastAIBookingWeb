prisma:query SELECT "public"."Customer"."id", "public"."Customer"."firstName", "public"."Customer"."lastName", "public"."Customer"."phone", "public"."Customer"."createdAt" FROM "public"."Customer" WHERE ("public"."Customer"."id" = $1 AND 1=1) LIMIT $2 OFFSET $3
prisma:query SELECT "public"."Appointment"."id", "public"."Appointment"."salonId", "public"."Appointment"."staffId", "public"."Appointment"."serviceId", "public"."Appointment"."startTime", "public"."Appointment"."status"::text, "public"."Appointment"."source"::text, "public"."Appointment"."createdAt", "public"."Appointment"."notes" FROM "public"."Appointment" WHERE "public"."Appointment"."customerId" = $1 OFFSET $2
prisma:query SELECT "public"."BookingAttempt"."id", "public"."BookingAttempt"."callSessionId", "public"."BookingAttempt"."appointmentId" FROM "public"."BookingAttempt" WHERE "public"."BookingAttempt"."appointmentId" IN ($1) OFFSET $2
prisma:query SELECT "public"."CallSession"."id", "public"."CallSession"."providerCallId" FROM "public"."CallSession" WHERE "public"."CallSession"."id" IN ($1) OFFSET $2
