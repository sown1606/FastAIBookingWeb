prisma:query SELECT "public"."Appointment"."id", "public"."Appointment"."customerId", "public"."Appointment"."source"::text, "public"."Appointment"."createdAt" FROM "public"."Appointment" WHERE ("public"."Appointment"."id" = $1 AND 1=1) LIMIT $2 OFFSET $3
prisma:query SELECT "public"."BookingAttempt"."id", "public"."BookingAttempt"."callSessionId", "public"."BookingAttempt"."appointmentId" FROM "public"."BookingAttempt" WHERE "public"."BookingAttempt"."appointmentId" IN ($1) OFFSET $2
prisma:query SELECT "public"."CallSession"."id", "public"."CallSession"."providerCallId" FROM "public"."CallSession" WHERE "public"."CallSession"."id" IN ($1) OFFSET $2
prisma:query DELETE FROM "public"."Appointment" WHERE ("public"."Appointment"."id" = $1 AND 1=1) RETURNING "public"."Appointment"."id", "public"."Appointment"."customerId"
prisma:query SELECT COUNT(*) FROM (SELECT "public"."Appointment"."id" FROM "public"."Appointment" WHERE "public"."Appointment"."customerId" = $1 OFFSET $2) AS "sub"
prisma:query DELETE FROM "public"."Customer" WHERE ("public"."Customer"."id" = $1 AND 1=1) RETURNING "public"."Customer"."id", "public"."Customer"."firstName", "public"."Customer"."lastName", "public"."Customer"."phone"
