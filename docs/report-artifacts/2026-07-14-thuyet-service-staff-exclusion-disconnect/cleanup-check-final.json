prisma:query SELECT "public"."CallSession"."id", "public"."CallSession"."providerCallId" FROM "public"."CallSession" WHERE ("public"."CallSession"."providerCallId"::text LIKE $1 AND "public"."CallSession"."createdAt" >= $2) OFFSET $3
prisma:query SELECT "public"."BookingAttempt"."id", "public"."BookingAttempt"."callSessionId", "public"."BookingAttempt"."appointmentId", "public"."BookingAttempt"."customerPhone", "public"."BookingAttempt"."customerName", "public"."BookingAttempt"."createdAt" FROM "public"."BookingAttempt" WHERE "public"."BookingAttempt"."callSessionId" IN ($1,$2,$3,$4,$5) OFFSET $6
prisma:query SELECT "public"."Customer"."id", "public"."Customer"."firstName", "public"."Customer"."lastName", "public"."Customer"."phone", "public"."Customer"."createdAt" FROM "public"."Customer" WHERE ("public"."Customer"."salonId" = $1 AND "public"."Customer"."phone"::text LIKE $2 AND "public"."Customer"."createdAt" >= $3) OFFSET $4
