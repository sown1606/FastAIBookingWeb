{
  "name": "@fastaibooking/api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test LOG_LEVEL=fatal JWT_SECRET=unit-test-jwt-secret-value REFRESH_TOKEN_SECRET=unit-test-refresh-secret-value DATABASE_URL=postgresql://unit:unit@localhost:5432/fastaibooking_unit FASTAIBOOKING_API_INTERNAL_TOKEN=unit-internal-token DEFAULT_SALON_ID=salon-default AMAZON_CONNECT_QUEUE_ID_DEFAULT=queue-default tsx --test --test-concurrency=1 \"test/**/*.test.ts\"",
    "simulate:callrail-booking": "tsx scripts/simulate-callrail-booking.ts",
    "simulate:callrail-escalation": "tsx scripts/simulate-callrail-escalation.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-pinpoint-sms-voice-v2": "^3.1045.0",
    "@aws-sdk/client-sesv2": "^3.1045.0",
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^14.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.5.0",
    "nodemailer": "^6.9.14",
    "pino": "^9.3.2",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.7.4",
    "@types/nodemailer": "^6.4.15",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
