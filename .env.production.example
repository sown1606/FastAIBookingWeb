APP_NAME=FastAIBooking API
NODE_ENV=production
LOG_LEVEL=info
PORT=3000
API_PREFIX=/api/v1
API_BASE_URL=https://api-new-nail.kendemo.com
CORS_ORIGINS=https://admin-new-nail.kendemo.com,https://app-new-nail.kendemo.com
ADMIN_FRONTEND_URL=https://admin-new-nail.kendemo.com
OWNER_FRONTEND_URL=https://app-new-nail.kendemo.com

VITE_API_BASE_URL=https://api-new-nail.kendemo.com
VITE_ADMIN_BASE_URL=https://admin-new-nail.kendemo.com
VITE_APP_BASE_URL=https://app-new-nail.kendemo.com
VITE_ADMIN_APP_NAME=FastAIBooking Admin
VITE_OWNER_APP_NAME=FastAIBooking
