VITE_AMAZON_CONNECT_CCP_URL=https://your-connect-instance.my.connect.aws/ccp-v2/

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=fastaibooking
DATABASE_USER=fastaibooking
DATABASE_PASSWORD=
DATABASE_URL=
DATABASE_SSL=false

JWT_SECRET=
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES_IN=30d

# Required for production email. Use either SMTP or AWS SES.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=FastAIBooking
EMAIL_PROVIDER=aws_ses
AWS_SES_REGION=us-east-1
AWS_SES_FROM_EMAIL=
AWS_SES_CONFIGURATION_SET=

RESET_PASSWORD_URL=https://app-new-nail.kendemo.com/reset-password
VERIFY_EMAIL_URL=https://app-new-nail.kendemo.com/verify-email
STAFF_INVITE_APP_LINK=https://app-new-nail.kendemo.com/download-demo-app
FEEDBACK_PUBLIC_URL=https://app-new-nail.kendemo.com/feedback

# Required for production SMS if SMS notifications are enabled.
SMS_PROVIDER=aws
SMS_FROM_NUMBER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=
AWS_END_USER_MESSAGING_REGION=us-east-1
AWS_SMS_ORIGINATION_NUMBER=
AWS_SMS_CONFIGURATION_SET=

