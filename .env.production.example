DOMAIN_APP=app-new-nail.kendemo.com
SERVER_IP=
LETSENCRYPT_EMAIL=ops@example.com

CALL_PROVIDER=amazon_connect
# Use amazon or lex for the Amazon Lex live demo path.
AI_PROVIDER=amazon

DEMO_SALON_NAME=Kiet Nails & Beauty
DEMO_ORIGINAL_PHONE_NUMBER=8487029493
DEMO_FORWARDING_PHONE_NUMBER=18483487681
DEMO_CARRIER=tmobile
DEMO_FORWARDING_TYPE=no_answer
DEMO_FORWARDING_ACTIVATION_CODE="**61*18483487681**10#"
DEMO_FORWARDING_DEACTIVATION_CODE="##61#"
