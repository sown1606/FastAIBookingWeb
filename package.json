{
  "name": "fastaibooking",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/admin",
    "apps/app"
  ],
  "scripts": {
    "dev:api": "npm --prefix apps/api run dev",
    "dev:admin": "npm --prefix apps/admin run dev",
    "dev:app": "npm --prefix apps/app run dev",
    "test": "npm run test:lambda && npm run test:api",
    "test:api": "npm --prefix apps/api run test",
    "test:lambda": "NODE_ENV=test FASTAIBOOKING_TEST_NOW_ISO=2026-07-17T10:00:00-04:00 node --test --test-concurrency=1 tests/lambda/*.test.mjs",
    "build:api": "npm --prefix apps/api run build",
    "build:admin": "npm --prefix apps/admin run build",
    "build:app": "npm --prefix apps/app run build",
    "start:api": "npm --prefix apps/api run start",
    "typecheck:api": "npm --prefix apps/api run typecheck",
    "typecheck:admin": "npm --prefix apps/admin run typecheck",
    "typecheck:app": "npm --prefix apps/app run typecheck",
    "simulate:callrail-booking": "npm --prefix apps/api run simulate:callrail-booking",
    "simulate:callrail-escalation": "npm --prefix apps/api run simulate:callrail-escalation",
    "migrate": "npm --prefix apps/api run prisma:migrate:deploy",
    "seed": "npm --prefix apps/api run prisma:seed",
    "aws:verify-identity": "bash scripts/aws/verify-fastaibooking-aws-identity.sh",
    "voice:release:validate": "bash scripts/aws/deploy-voice-stack.sh validate-source",
    "voice:release:plan": "bash scripts/aws/deploy-voice-stack.sh plan",
    "voice:release:deploy-canary": "bash scripts/aws/deploy-voice-stack.sh deploy-canary",
    "voice:release:record-case": "bash scripts/aws/deploy-voice-stack.sh record-canary-case",
    "voice:release:summarize": "bash scripts/aws/deploy-voice-stack.sh summarize",
    "voice:release:promote:dry-run": "bash scripts/aws/deploy-voice-stack.sh promote-production --dry-run",
    "voice:release:promote": "bash scripts/aws/deploy-voice-stack.sh promote-production",
    "voice:release:verify": "bash scripts/aws/deploy-voice-stack.sh verify",
    "voice:release:rollback": "bash scripts/aws/deploy-voice-stack.sh rollback",
    "voice:deploy:canary:dry-run": "bash scripts/aws/deploy-voice-stack.sh --target canary --dry-run",
    "voice:deploy:canary": "bash scripts/aws/deploy-voice-stack.sh --target canary",
    "voice:deploy:production:dry-run": "bash scripts/aws/deploy-voice-stack.sh --target production --dry-run",
    "voice:deploy:production": "bash scripts/aws/deploy-voice-stack.sh --target production",
    "deploy:ec2": "./infra/scripts/deploy_remote_ec2.sh",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  }
}
